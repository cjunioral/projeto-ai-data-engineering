import json

# Dados dos feedbacks dos clientes
feedbacks = [
    {'id': 1, 'produto_nome_bruto': 'tomate cereja 200g', 'comentario_cliente': 'Alguns tomates vieram amassados no fundo da embalagem.'},
    {'id': 2, 'produto_nome_bruto': 'pao de forma artesanal', 'comentario_cliente': 'Muito macio e fresquinho, adorei!'},
    {'id': 3, 'produto_nome_bruto': 'carne moida patinho', 'comentario_cliente': 'A carne estava com muita gordura dessa vez.'},
    {'id': 4, 'produto_nome_bruto': 'detergente', 'comentario_cliente': 'O cheiro é bom, mas nao faz muita espuma.'}
]

# Função para analisar o sentimento do feedback
def analisar_sentimento(comentario_cliente):
    palavras_chave_positivas = ['adorei', 'muito', 'fresquinho', 'bom']
    palavras_chave_negativas = ['amassados', 'gordura', 'nao faz']
    
    sentimento = 'Positivo' if any(palavra in comentario_cliente.lower() for palavra in palavras_chave_positivas) else 'Negativo'
    return sentimento

# Função para avaliar a urgência do feedback
def avaliar_urgencia(comentario_cliente):
    urgencia = 3  # Valor padrão
    
    if 'amassados' in comentario_cliente.lower() or 'gordura' in comentario_cliente.lower():
        urgencia = 5  # Alta urgência
    elif 'nao faz' in comentario_cliente.lower():
        urgencia = 2  # Média urgência
    
    return urgencia

# Função para gerar a ação recomendada
def gerar_acao_recomendada(sentimento, comentario_cliente):
    if sentimento == 'Positivo':
        return 'Parabéns! Continuem fazendo um ótimo trabalho!'
    elif sentimento == 'Negativo':
        return 'Peço desculpas pelo problema. Vamos melhorar nossa qualidade!'
    else:
        return 'Ação não definida'

# Analisar os feedbacks e gerar o JSON
feedbacks_analisados = []
for feedback in feedbacks:
    sentimento = analisar_sentimento(feedback['comentario_cliente'])
    urgencia = avaliar_urgencia(feedback['comentario_cliente'])
    acao_recomendada = gerar_acao_recomendada(sentimento, feedback['comentario_cliente'])
    
    feedback_analisado = {
        'id': feedback['id'],
        'sentimento': sentimento,
        'urgencia': urgencia,
        'acao_recomendada': acao_recomendada
    }
    
    feedbacks_analisados.append(feedback_analisado)

# Converter a lista de feedbacks em JSON
json_feedbacks = json.dumps(feedbacks_analisados, indent=4)

print(json_feedbacks)
